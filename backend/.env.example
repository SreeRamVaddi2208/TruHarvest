# Odoo Connection
ODOO_URL=http://localhost:8069
ODOO_DB=your-odoo-database
ODOO_USERNAME=your-odoo-email@example.com
ODOO_PASSWORD=your-odoo-api-key

# Odoo REST API – Markwave products only (base URL; /products is appended)
ODOO_REST_API_URL=http://localhost:8000/markwave

# Set to true to fetch products/stock only from Odoo (frontend shows exact Odoo data)
PREFER_ODOO_FOR_PRODUCTS=false

# Markwave company ID in Odoo (for XML-RPC filtering)
ODOO_MARKWAVE_COMPANY_ID=2

# PostgreSQL (Direct Access)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your-database-name
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password

# Security
SECRET_KEY=change-this-to-a-random-secret-key
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# API Settings
API_V1_PREFIX=/api/v1
DEBUG=true

# App user role: viewer (read-only), controller (accept draft & update state), admin (full)
APP_USER_ROLE=admin
